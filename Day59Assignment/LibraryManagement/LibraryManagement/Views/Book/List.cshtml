@model IEnumerable<LibraryManagement.Models.Book>

<h2>Book List</h2>

<a asp-action="Create" class="btn btn-primary">Add Book</a>
<br />
<br />
<br />

<table class="table table-striped table-dark">
    <tr>
        <th>ID</th>
        <th>Title</th>
        <th>Author</th>
        <th>Price</th>
        <th>Action</th>
    </tr>

    @foreach (var book in Model)
    {
        <tr>
            <td>@book.BookId</td>
            <td>@book.Title</td>
            <td>@book.Author</td>
            <td>@book.Price</td>
            <td>
                <a asp-action="Details" asp-route-id="@book.BookId" class="btn btn-primary">View</a>
                <a asp-action="Delete" asp-route-id="@book.BookId" class="btn btn-success">Delete</a>
            </td>
        </tr>
    }

</table>